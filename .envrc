if ! command -v git &> /dev/null || ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Not in a git repo, blocking direnv"
  exit 1
fi

: "${ENV:=development}"

if [ -z "$ENV_SET_EXPLICITLY" ]; then
  branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "unknown")
  case "$branch" in
    main|master|production) ENV=production ;;
    *) ENV=development ;;
  esac
fi

export ENV
export DOTENV_CONFIG_QUIET=true

[ -f ".env" ] && dotenv .env
[ -f ".env.local" ] && dotenv .env.local
[ -f ".env.${ENV}" ] && dotenv ".env.${ENV}"

watch_file .env .env.local ".env.${ENV}"
