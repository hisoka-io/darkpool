    let (nf, _, _, ct1, _, _, ct2, _) = main(
        merkle_root,
        current_timestamp,
        compliance_pubkey_x,
        compliance_pubkey_y,
        note_in,
        secret_in,
        index_in,
        path_in,
        preimage_in,
