{
  "name": "@hisoka/wallets",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./frost": {
      "types": "./dist/frost/index.d.ts",
      "import": "./dist/frost/index.js",
      "require": "./dist/frost/index.cjs"
    },
    "./threshold": {
      "types": "./dist/threshold/index.d.ts",
      "import": "./dist/threshold/index.js",
      "require": "./dist/threshold/index.cjs"
    },
    "./unsafe-sim": {
      "types": "./dist/unsafe-sim/index.d.ts",
      "import": "./dist/unsafe-sim/index.js",
      "require": "./dist/unsafe-sim/index.cjs"
    },
    "./reference": {
      "types": "./dist/reference.d.ts",
      "import": "./dist/reference.js",
      "require": "./dist/reference.cjs"
    }
  },
  "scripts": {
    "clean": "rm -rf dist *.tsbuildinfo",
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix"
  },
  "author": "hisoka-io",
  "license": "Apache-2.0",
  "devDependencies": {
    "@noble/curves": "1.9.1",
    "@types/node": "^24.10.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.2",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@aztec/foundation": "^2.0.4",
    "@zk-kit/baby-jubjub": "^1.0.3",
    "@zk-kit/utils": "^1.4.1",
    "bs58check": "^4.0.0",
    "ethers": "^6.15.0"
  }
}
