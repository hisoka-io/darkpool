{
  "compilerOptions": {
    "target": "es2020",
    "module": "preserve",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "outDir": "./dist"
  },
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node"
    }
  },
  "include": [
    "./hardhat.config.ts",
    "./test/**/*",
    "./scripts/**/*",
    "./typechain-types"
  ],
  "exclude": [
    "node_modules",
    "dist",
    // Dead against a deleted API: imports deriveSharedSecret / NotePlaintext / computeOwner, none of which
    // exist in @hisoka/wallets, and targets the abandoned Arbitrum-Sepolia deploy. Quarantined so the full
    // typecheck gate can run over everything else; pending a decision to delete it outright.
    "test/nox/live_zk_traffic.ts"
  ]
}
